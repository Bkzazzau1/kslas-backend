APP_NAME=kslasbackend
APP_ENV=development
APP_PORT=8080

DATABASE_URL=postgres://postgres:postgres@localhost:5432/kslasbackend?sslmode=disable
JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars
JWT_EXPIRES_HOURS=24
STORAGE_DIR=storage
MAX_UPLOAD_BYTES=1073741824

DB_MAX_IDLE_CONNS=5
DB_MAX_OPEN_CONNS=20
DB_CONN_MAX_LIFETIME=30m

AUTO_MIGRATE=true
SEED_RBAC=true

BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_FIRST_NAME=System
BOOTSTRAP_ADMIN_LAST_NAME=Admin
